# LinkedIn Developer App credentials (capture from https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# OAuth redirect URI registered in your LinkedIn app (default works for local flow)
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback

# Populated automatically by `./bin/lp auth`
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_ACCESS_TOKEN_EXPIRES_AT=
LINKEDIN_PERSON_URN=

# LinkedIn API version (bump quarterly; see deprecation calendar)
LINKEDIN_API_VERSION=202504
